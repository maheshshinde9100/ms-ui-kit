{
  "name": "ms-ui-kit",
  "version": "0.3.0",
  "description": "Reusable React UI components library",
  "type": "module",
  "main": "./dist/components/index.js",
  "module": "./dist/components/index.js",
  "exports": {
    ".": {
      "import": "./dist/components/index.js"
    },
    "./components/*": {
      "import": "./dist/components/*/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "tree-shaking"
  ],
  "author": "Mahesh Shinde",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maheshshinde9100/ms-ui-kit.git"
  },
  "bugs": {
    "url": "https://github.com/maheshshinde9100/ms-ui-kit/issues"
  },
  "homepage": "https://github.com/maheshshinde9100/ms-ui-kit#readme",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "lint": "eslint .",
    "preview": "vite preview",
    "analyze": "vite build --mode analyze",
    "size": "npm run build:lib && du -sh dist/"
  },
  "dependencies": {
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "prop-types": "^15.8.1",
    "react-router-dom": "^6.30.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.17",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.17",
    "vite": "^7.2.4"
  }
}
